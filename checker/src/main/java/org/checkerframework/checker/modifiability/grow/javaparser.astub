import org.checkerframework.checker.modifiability.qual.Modifiable;
import org.checkerframework.checker.modifiability.qual.IteratorPolyShrinkable;

package com.github.javaparser.ast.stmt;

class BlockStmt {
  public @Modifiable NodeList<Statement> getStatements() {}
}

package com.github.javaparser.ast;

class CompilationUnit {
  public @Modifiable @IteratorPolyShrinkable NodeList<ImportDeclaration> getImports() {}
}
